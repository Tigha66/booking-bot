# Booking Bot Configuration

# Service Fee (per booking)
SERVICE_FEE=2.99

# Flights API (Amadeus/Skyscanner)
FLIGHTS_API_KEY=your_flights_api_key
FLIGHTS_API_SECRET=your_flights_api_secret

# Hotels API (Booking.com/Expedia)
HOTELS_API_KEY=your_hotels_api_key
HOTELS_API_SECRET=your_hotels_api_secret

# Restaurants API (OpenTable/Yelp)
RESTAURANTS_API_KEY=your_restaurants_api_key

# Payment - Stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key

# Email (SMTP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=465
EMAIL_USER=your_email@gmail.com
EMAIL_PASS=your_app_password

# Telegram Bot
TELEGRAM_BOT_TOKEN=your_telegram_bot_token

# WhatsApp
WHATSAPP_SESSION=./sessions/whatsapp
